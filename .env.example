# ===========================================
# CurbAI V1 — Environment Variables
# ===========================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# --- LLM Provider ---
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Database (PostgreSQL 15) ---
POSTGRES_USER=curbai
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=curbai_v1
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=curbai
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/

# --- JWT Auth ---
JWT_SECRET=generate_a_256_bit_random_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# --- Notification Channels ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# --- Service Ports (internal) ---
INGESTION_SERVICE_PORT=8001
INTELLIGENCE_SERVICE_PORT=8002
NOTIFICATION_SERVICE_PORT=8003
REPORT_SERVICE_PORT=8004
API_GATEWAY_PORT=8000

# --- ML ---
ML_SCORING_THRESHOLD=40
AGENT_TRIGGER_THRESHOLD=55
MODEL_STORE_PATH=/app/model_store
